{
  "schemaVersion": 1,
  "id": "mc-friend-finder",
  "version": "${version}",
  "name": "MC Friend Finder",
  "description": "Browse Minecraft servers found by your own self-hosted scanner, and add them to your Multiplayer server list or connect directly. Not affiliated with, and does not depend on, any third-party ServerSeeker service.",
  "authors": [
    "MC Friend Finder Contributors"
  ],
  "contact": {
    "sources": "https://github.com/YOUR_USERNAME/MC-Friend-Finder"
  },
  "license": "AGPL-3.0-or-later",
  "icon": "assets/mcfriendfinder/icon.png",
  "environment": "client",
  "entrypoints": {
    "meteor": [
      "dev.mcfriendfinder.addon.ServerFinderAddon"
    ]
  },
  "mixins": [
    "mcfriendfinder.mixins.json"
  ],
  "custom": {
    "meteor-client:color": "40,180,99",
    "modmenu": {
      "parent": {
        "id": "meteor-client"
      }
    }
  },
  "depends": {
    "java": ">=${jdk_version}",
    "minecraft": "${minecraft_version}",
    "meteor-client": "*"
  }
}
